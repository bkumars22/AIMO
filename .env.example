# ════════════════════════════════════════════════════════════════
# AIMO — AI Incident Management & Observability Platform
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.
# ════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────
DB_USER=aimo
DB_PASSWORD=aimo_secret
DB_NAME=aimo
# Used directly by the AI engine (Python/SQLAlchemy)
DATABASE_URL=postgresql://aimo:aimo_secret@localhost:5432/aimo
# Used by Spring Boot (JDBC format)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/aimo
SPRING_DATASOURCE_USERNAME=aimo
SPRING_DATASOURCE_PASSWORD=aimo_secret

# ── AI Models ─────────────────────────────────────────────────
# Anthropic — Claude Haiku for root-cause synthesis
ANTHROPIC_API_KEY=sk-ant-...

# Groq — Llama-3.3-70b for detection LLM calls (free tier)
GROQ_API_KEY=gsk_...

# ── LangSmith (optional — tracing for AIMO's own pipeline) ────
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=AIMO-Production
LANGCHAIN_TRACING_V2=true
LANGSMITH_BASE_URL=https://api.smith.langchain.com
LANGSMITH_POLL_INTERVAL_SEC=300

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_ALERT_CHANNEL=aimo:incidents

# ── Security ──────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_in_production_use_256_bit_random_string

# ── Alerts ────────────────────────────────────────────────────
AIMO_ALERT_WEBHOOK=https://hooks.slack.com/services/T.../B.../...
ALERT_EMAIL_FROM=aimo-alerts@yourdomain.com
ALERT_EMAIL_TO=oncall@yourdomain.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password

# ── Detection Thresholds ──────────────────────────────────────
# Hallucination — deepeval Faithfulness (0.0–1.0, lower = more permissive)
HALLUCINATION_FAITHFULNESS_THRESHOLD=0.70
# Hallucination — deepeval AnswerConsistency on same-input reruns
HALLUCINATION_CONSISTENCY_THRESHOLD=0.85
# Fraction of requests to analyze (1.0 = every request)
HALLUCINATION_SAMPLE_RATE=0.20

# Cost spike — multiplier over 7-day rolling average
COST_SPIKE_MULTIPLIER=3.0
# Absolute ceiling per single run regardless of average
COST_SPIKE_ABSOLUTE_CEILING_USD=0.50
# Groq free-tier daily limit (used for quota projection)
GROQ_DAILY_TOKEN_LIMIT=100000

# Compliance drift — minimum acceptable rate (0–1)
COMPLIANCE_MIN_RATE=0.90
# Fraction of live traffic to shadow-eval against golden dataset
COMPLIANCE_SHADOW_EVAL_RATE=0.10

# Latency — multiplier over P95 baseline
LATENCY_SPIKE_MULTIPLIER=2.0
# z-score threshold for IsolationForest latency detection
LATENCY_ZSCORE_THRESHOLD=2.5

# Prompt injection — pgvector cosine similarity cutoff (0–1)
INJECTION_SIMILARITY_THRESHOLD=0.85

# ── Scheduler ─────────────────────────────────────────────────
COMPLIANCE_EVAL_INTERVAL_MIN=60

# ── Server ────────────────────────────────────────────────────
AIMO_PORT=8001
AIMO_ENV=production
# URL where this AI engine is reachable (used by SDK @aimo_trace)
AIMO_ENDPOINT=http://localhost:8001

# ── Integrations (Prompt 10) ──────────────────────────────────
# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# GitHub auto-issue creation on P0/P1
GITHUB_TOKEN=ghp_...
GITHUB_REPO=bkumars22/AIMO

# Dashboard URL (used in Slack/GitHub links)
DASHBOARD_URL=http://localhost:3000

# QAIP connector (for meta-observability)
QAIP_PIPELINE_ID=
AIMO_API_KEY=

# AIPQ connector — root-cause check for HALLUCINATION/QUALITY_DEGRADATION
# incidents (was this caused by a recent prompt change, or model drift?)
AIPQ_BASE_URL=http://localhost:8001
AIPQ_API_KEY=
# Maps AIMO pipeline_id -> node_name -> the AIPQ project/prompt tracking that
# node's prompt, so classify_incidents can auto-attach aipq_project_id/
# aipq_prompt_name to incident evidence. Leave as {} if no pipeline is AIPQ-tracked yet.
AIPQ_PIPELINE_MAP={"aria-prod": {"teach_socratically": {"project_id": 1, "prompt_name": "aria_socratic_system"}}}

# Rate limiting
RATE_LIMIT_PER_MINUTE=100

# Eval cache TTL (Redis)
EVAL_CACHE_TTL_SEC=3600

# IsolationForest contamination rate (0.0–0.5)
ISOLATION_CONTAMINATION=0.10

# Demo seeder
DEMO_SEED=0

# ── Frontend ──────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080
VITE_AI_ENGINE_URL=http://localhost:8001
VITE_WS_URL=ws://localhost:8001/ws/dashboard
